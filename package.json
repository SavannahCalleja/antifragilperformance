{
  "name": "antifragil-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile:start": "npm run start -w @antifragil/mobile",
    "mobile:ios": "npm run ios -w @antifragil/mobile",
    "mobile:android": "npm run android -w @antifragil/mobile",
    "mobile:test": "npm run test -w @antifragil/mobile",
    "mobile:lint": "npm run lint -w @antifragil/mobile",
    "mobile:typecheck": "npm run typecheck -w @antifragil/mobile",
    "mobile:embed-privacy": "npm run embed-privacy -w @antifragil/mobile",
    "web:dev": "npm run dev -w @antifragil/web",
    "web:build": "npm run build -w @antifragil/web",
    "web:start": "npm run start -w @antifragil/web",
    "web:lint": "npm run lint -w @antifragil/web",
    "web:typecheck": "npm run typecheck -w @antifragil/web",
    "web:icons": "npm run icons -w @antifragil/web",
    "shared:typecheck": "npm run typecheck -w @antifragil/shared-api",
    "typecheck": "npm run mobile:typecheck && npm run web:typecheck && npm run shared:typecheck"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
